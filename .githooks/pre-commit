#!/bin/sh

# GUI git clients often lack ~/.cargo/bin in PATH
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Format Rust code
cargo fmt --check || {
    echo "Run 'cargo fmt' to fix formatting"
    exit 1
}

# Lint TypeScript (if node_modules exists)
if [ -d "node_modules" ]; then
    npm run lint || exit 1
fi
